@using ProTracker.Models
@{
    ViewData["Title"] = "Home";
}

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <!-- Logged in welcome -->
    <div class="px-4 py-5 text-center mb-4"
         style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); border-radius: 16px; color: white;">
        <h1 class="display-4 fw-bold mb-2">Welcome back 👋</h1>
        <p class="lead mb-4" style="color: #a0aec0;">Ready to crush today's training?</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Home" asp-action="Dashboard" class="btn btn-light btn-lg px-4">📊 Dashboard</a>
            @if (User.IsInRole("Coach"))
            {
                <a asp-controller="TrainingPlans" asp-action="Index" class="btn btn-outline-light btn-lg px-4">👥 My Athletes</a>
                <a asp-controller="TrainingPlans" asp-action="Create" class="btn btn-success btn-lg px-4">+ New Plan</a>
            }
            @if (User.IsInRole("Athlete"))
            {
                <a asp-controller="Dashboard" asp-action="AthleteDashboard" class="btn btn-outline-light btn-lg px-4">📋 My Plans</a>
            }
        </div>
    </div>

    <!-- Quick links -->
    <div class="row g-4">
        <div class="col-md-4">
            <a asp-controller="Home" asp-action="Dashboard" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 text-center p-3" style="transition: transform 0.2s;"
                     onmouseover="this.style.transform='translateY(-4px)'"
                     onmouseout="this.style.transform='translateY(0)'">
                    <div class="card-body">
                        <div style="font-size: 3rem;">📊</div>
                        <h5 class="fw-bold mt-3 text-dark">Dashboard</h5>
                        <p class="text-muted">
                            @if (User.IsInRole("Coach"))
                            {
                                <span>View stats, athlete progress and recent activity at a glance.</span>
                            }
                            else
                            {
                                <span>View your stats, active plan and overall progress at a glance.</span>
                            }
                        </p>
                        <span class="btn btn-sm btn-outline-primary mt-2">Go to Dashboard →</span>
                    </div>
                </div>
            </a>
        </div>

        @if (User.IsInRole("Coach"))
        {
            <div class="col-md-4">
                <a asp-controller="TrainingPlans" asp-action="Index" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 text-center p-3" style="transition: transform 0.2s;"
                         onmouseover="this.style.transform='translateY(-4px)'"
                         onmouseout="this.style.transform='translateY(0)'">
                        <div class="card-body">
                            <div style="font-size: 3rem;">👥</div>
                            <h5 class="fw-bold mt-3 text-dark">My Athletes</h5>
                            <p class="text-muted">Manage training plans organized by athlete. Add tasks, edit and delete.</p>
                            <span class="btn btn-sm btn-outline-primary mt-2">View Athletes →</span>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="TrainingPlans" asp-action="Create" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 text-center p-3" style="transition: transform 0.2s;"
                         onmouseover="this.style.transform='translateY(-4px)'"
                         onmouseout="this.style.transform='translateY(0)'">
                        <div class="card-body">
                            <div style="font-size: 3rem;">➕</div>
                            <h5 class="fw-bold mt-3 text-dark">Create Plan</h5>
                            <p class="text-muted">Build a new training plan and assign it to one of your athletes.</p>
                            <span class="btn btn-sm btn-outline-success mt-2">Create Now →</span>
                        </div>
                    </div>
                </a>
            </div>
        }

        @if (User.IsInRole("Athlete"))
        {
            <div class="col-md-4">
                <a asp-controller="Dashboard" asp-action="AthleteDashboard" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 text-center p-3" style="transition: transform 0.2s;"
                         onmouseover="this.style.transform='translateY(-4px)'"
                         onmouseout="this.style.transform='translateY(0)'">
                        <div class="card-body">
                            <div style="font-size: 3rem;">📋</div>
                            <h5 class="fw-bold mt-3 text-dark">My Plans</h5>
                            <p class="text-muted">View all your assigned training plans and track your progress.</p>
                            <span class="btn btn-sm btn-outline-primary mt-2">View My Plans →</span>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="TrainingPlans" asp-action="Details" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 text-center p-3" style="transition: transform 0.2s;"
                         onmouseover="this.style.transform='translateY(-4px)'"
                         onmouseout="this.style.transform='translateY(0)'">
                        <div class="card-body">
                            <div style="font-size: 3rem;">✅</div>
                            <h5 class="fw-bold mt-3 text-dark">Track Tasks</h5>
                            <p class="text-muted">Mark tasks as In Progress or Completed to update your progress.</p>
                            <span class="btn btn-sm btn-outline-success mt-2">View Tasks →</span>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}
else
{
    <!-- Logged out landing -->
    <div class="px-4 py-5 text-center mb-4"
         style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); border-radius: 16px; color: white;">
        <h1 class="display-3 fw-bold mb-3">ProTracker 🏋️</h1>
        <p class="lead mb-4" style="color: #a0aec0; font-size: 1.3rem;">
            A platform for coaches and athletes to manage training plans, track tasks, and stay organized.
        </p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-light btn-lg px-5">Get Started →</a>
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-light btn-lg px-5">Log In</a>
        </div>
    </div>

    <!-- Feature cards -->
    <div class="row g-4 mt-2">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-3">
                <div class="card-body">
                    <div style="font-size: 3rem;">📋</div>
                    <h5 class="fw-bold mt-3">Training Plans</h5>
                    <p class="text-muted">Coaches can create structured training programs and assign them to athletes.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-3">
                <div class="card-body">
                    <div style="font-size: 3rem;">✅</div>
                    <h5 class="fw-bold mt-3">Task Tracking</h5>
                    <p class="text-muted">Track tasks with real-time status updates and progress bars.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-3">
                <div class="card-body">
                    <div style="font-size: 3rem;">📊</div>
                    <h5 class="fw-bold mt-3">Progress Tracking</h5>
                    <p class="text-muted">Visual progress indicators help coaches and athletes stay on track.</p>
                </div>
            </div>
        </div>
    </div>
}