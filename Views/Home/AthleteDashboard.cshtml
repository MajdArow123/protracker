@using ProTracker.Models
@using TaskStatus = ProTracker.Models.TaskStatus
@{
    ViewData["Title"] = "Athlete Dashboard";
    var myPlans = ViewBag.MyPlans as List<TrainingPlan> ?? new();
    var activePlan = ViewBag.ActivePlan as TrainingPlan;
}

<!-- Hero -->
<div class="px-4 py-5 text-center mb-4"
     style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); border-radius: 16px; color: white;">
    <h1 class="display-5 fw-bold mb-2">🏋️ Athlete Dashboard</h1>
    <p class="lead mb-4" style="color: #a0aec0;">Track your training and crush your goals</p>
    <a asp-controller="TrainingPlans" asp-action="Index" class="btn btn-light btn-lg px-4">📋 View All My Plans</a>
</div>

<!-- Stats cards -->
<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #4299e1 !important;">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <span style="font-size: 2rem;">📋</span>
                    <div>
                        <div class="text-muted small">Assigned Plans</div>
                        <div class="fw-bold fs-4">@ViewBag.TotalPlans</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #48bb78 !important;">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <span style="font-size: 2rem;">✅</span>
                    <div>
                        <div class="text-muted small">Tasks Completed</div>
                        <div class="fw-bold fs-4">@ViewBag.CompletedTasks</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #f6ad55 !important;">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <span style="font-size: 2rem;">🔄</span>
                    <div>
                        <div class="text-muted small">In Progress</div>
                        <div class="fw-bold fs-4">@ViewBag.InProgressTasks</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #9f7aea !important;">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <span style="font-size: 2rem;">📊</span>
                    <div>
                        <div class="text-muted small">Overall Progress</div>
                        <div class="fw-bold fs-4">@ViewBag.OverallPercent%</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Overall progress bar -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body px-4 py-3">
        <div class="d-flex justify-content-between mb-1">
            <span class="fw-semibold">Overall Completion</span>
            <span class="fw-bold">@ViewBag.OverallPercent%</span>
        </div>
        <div class="progress" style="height: 14px; border-radius: 8px;">
            <div class="progress-bar
                @(ViewBag.OverallPercent == 100 ? "bg-success" :
                  ViewBag.OverallPercent >= 50 ? "bg-primary" : "bg-warning")"
                 role="progressbar"
                 style="width: @ViewBag.OverallPercent%; border-radius: 8px;"
                 aria-valuenow="@ViewBag.OverallPercent"
                 aria-valuemin="0" aria-valuemax="100">
            </div>
        </div>
        <div class="text-muted small mt-1">
            @ViewBag.CompletedTasks of @ViewBag.TotalTasks tasks completed across all plans
        </div>
    </div>
</div>

<!-- Active plan highlight -->
@if (activePlan != null)
{
    var activeDone = activePlan.Tasks.Count(t => t.Status == TaskStatus.Completed);
    var activeTotal = activePlan.Tasks.Count;
    var activePercent = activeTotal > 0 ? (int)((double)activeDone / activeTotal * 100) : 0;

    <div class="card border-0 shadow-sm mb-4 border-start border-primary border-4">
        <div class="card-body px-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                <div>
                    <span class="badge bg-primary mb-1">🔥 Active Plan</span>
                    <h5 class="fw-bold mb-1">@activePlan.Title</h5>
                    <p class="text-muted small mb-2">@activePlan.Goal</p>
                    <span class="text-muted small">
                        @activePlan.StartDate.ToString("MMM dd") → @activePlan.EndDate.ToString("MMM dd, yyyy")
                    </span>
                </div>
                <a asp-controller="TrainingPlans" asp-action="Details"
                   asp-route-id="@activePlan.TrainingPlanId"
                   class="btn btn-primary">View Tasks →</a>
            </div>
            <div class="mt-3">
                <div class="d-flex justify-content-between small mb-1">
                    <span>Progress</span>
                    <span class="fw-semibold">@activeDone / @activeTotal tasks</span>
                </div>
                <div class="progress" style="height: 10px;">
                    <div class="progress-bar bg-primary" role="progressbar"
                         style="width: @activePercent%"
                         aria-valuenow="@activePercent" aria-valuemin="0" aria-valuemax="100">
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- All assigned plans -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-4 px-4">
        <h4 class="fw-bold mb-0">📋 All My Training Plans</h4>
        <p class="text-muted small mb-0">Plans assigned to you by your coach</p>
    </div>
    <div class="card-body px-4">
        @if (!myPlans.Any())
        {
            <div class="alert alert-info">No plans assigned yet. Check back after your coach creates one for you.</div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var plan in myPlans)
                {
                    var done = plan.Tasks.Count(t => t.Status == TaskStatus.Completed);
                    var total = plan.Tasks.Count;
                    var pct = total > 0 ? (int)((double)done / total * 100) : 0;
                    var isComplete = pct == 100;

                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="fw-bold mb-0">@plan.Title</h6>
                                    @if (isComplete)
                                    {
                                        <span class="badge bg-success">✅ Done</span>
                                    }
                                    else if (done > 0)
                                    {
                                        <span class="badge bg-primary">🔄 In Progress</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">⏳ Not Started</span>
                                    }
                                </div>
                                <p class="text-muted small mb-2">@plan.Goal</p>
                                <div class="text-muted small mb-3">
                                    📅 @plan.StartDate.ToString("MMM dd") – @plan.EndDate.ToString("MMM dd, yyyy")
                                </div>
                                <div class="d-flex justify-content-between small mb-1">
                                    <span>Tasks</span>
                                    <span class="fw-semibold">@done / @total</span>
                                </div>
                                <div class="progress mb-3" style="height: 8px;">
                                    <div class="progress-bar @(isComplete ? "bg-success" : pct >= 50 ? "bg-primary" : "bg-warning")"
                                         role="progressbar" style="width: @pct%"></div>
                                </div>
                                <a asp-controller="TrainingPlans" asp-action="Details"
                                   asp-route-id="@plan.TrainingPlanId"
                                   class="btn btn-sm btn-outline-primary w-100">View Plan →</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
