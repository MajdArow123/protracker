@model ProTracker.Models.TaskItem
@using System
@using ModelTaskStatus = ProTracker.Models.TaskStatus

@{
    ViewData["Title"] = "Create Task";
    var trainingPlanId = (int)ViewBag.TrainingPlanId;
}

<h1>Create Task</h1>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input type="hidden" asp-for="TrainingPlanId" value="@trainingPlanId" />

    <div class="mb-3">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <input asp-for="Description" class="form-control" />
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" class="form-select">
            @foreach (ModelTaskStatus s in Enum.GetValues(typeof(ModelTaskStatus)))
            {
                <option value="@s">@s</option>
            }
        </select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DueDate" class="form-label"></label>
        <input asp-for="DueDate" type="date" class="form-control" />
        <span asp-validation-for="DueDate" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>

    <a asp-action="Index"
       asp-route-trainingPlanId="@trainingPlanId"
       class="btn btn-secondary">Cancel</a>
</form>