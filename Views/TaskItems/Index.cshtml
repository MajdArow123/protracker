@model IEnumerable<ProTracker.Models.TaskItem>

@{
    ViewData["Title"] = "Tasks";
    var trainingPlanId = (int)ViewBag.TrainingPlanId;
}

<h1>Tasks</h1>

<p>
    <a asp-action="Create" asp-route-trainingPlanId="@trainingPlanId" class="btn btn-success">Create New Task</a>
    <a asp-controller="TrainingPlans" asp-action="Index" class="btn btn-secondary">Back to Plans</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">No tasks yet. Create your first task above!</div>
}
else
{
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Status</th>
                <th>Due Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td>@t.Title</td>
                    <td>
                        @{
                            var badgeClass = t.Status switch {
                                "Done" => "badge bg-success",
                                "In Progress" => "badge bg-warning text-dark",
                                _ => "badge bg-primary"
                            };
                        }
                        <span class="@badgeClass">@t.Status</span>
                    </td>
                    <td>@(t.DueDate?.ToString("MMM dd, yyyy") ?? "No due date")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@t.TaskItemId" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@t.TaskItemId" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}