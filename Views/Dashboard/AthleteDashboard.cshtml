@model List<ProTracker.Models.TrainingPlan>
@{
    ViewData["Title"] = "Athlete Dashboard";
}

<div class="container mt-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-0">🏃 Athlete Dashboard</h2>
        <p class="text-muted mb-0">Your assigned training plans</p>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No training plans assigned to you yet. Check back soon!
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var plan in Model)
            {
                var total = plan.Tasks.Count;
                var completed = plan.Tasks.Count(t => t.Status.ToString() == "Completed");

                var percent = total > 0 ? (int)((double)completed / total * 100) : 0;

                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@plan.Title</h5>
                            <p class="text-muted small mb-2">@plan.StartDate.ToString("MMM d") – @plan.EndDate.ToString("MMM d, yyyy")</p>
                            @if (!string.IsNullOrEmpty(plan.Goal))
                            {
                                <p class="card-text small">🎯 @plan.Goal</p>
                            }

                            <div class="mb-2">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span>Progress</span>
                                    <span>@completed / @total tasks</span>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar bg-primary" style="width: @percent%"></div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent">
                            <a asp-controller="TrainingPlans" asp-action="Details"
                               asp-route-id="@plan.TrainingPlanId" class="btn btn-sm btn-outline-primary">
                                View Tasks
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>