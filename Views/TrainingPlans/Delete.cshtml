@model ProTracker.Models.TrainingPlan
@{
    ViewData["Title"] = "Delete Training Plan";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger border-2 shadow-sm">
                <div class="card-body p-4 text-center">
                    <div style="font-size: 3rem;">⚠️</div>
                    <h2 class="fw-bold mt-2">Delete Training Plan?</h2>
                    <p class="text-muted">This action cannot be undone.</p>

                    <div class="alert alert-light border mt-3 text-start">
                        <strong>@Model.Title</strong><br />
                        <span class="text-muted small">@Model.StartDate.ToString("MMM d") – @Model.EndDate.ToString("MMM d, yyyy")</span><br />
                        @if (!string.IsNullOrEmpty(Model.Goal))
                        {
                            <span class="small">🎯 @Model.Goal</span>
                        }
                    </div>

                    <div class="d-flex gap-2 justify-content-center mt-3">
                        <form asp-action="Delete" method="post">
                            <input type="hidden" name="id" value="@Model.TrainingPlanId" />
                            <button type="submit" class="btn btn-danger px-4">Yes, Delete</button>
                        </form>
                        <a asp-controller="Dashboard" asp-action="CoachDashboard"
                           class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>