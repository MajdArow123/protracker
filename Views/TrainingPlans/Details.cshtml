@model ProTracker.Models.TrainingPlan
@using ProTracker.Models
@using ModelTaskStatus = ProTracker.Models.TaskStatus
@{
    ViewData["Title"] = Model.Title;
    var completed = Model.Tasks.Count(t => t.Status == ModelTaskStatus.Completed);
    var total = Model.Tasks.Count;
    var percent = total > 0 ? (int)((double)completed / total * 100) : 0;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">📋 @Model.Title</h2>
            <p class="text-muted mb-0">@Model.StartDate.ToString("MMM d") – @Model.EndDate.ToString("MMM d, yyyy")</p>
        </div>
        <a asp-controller="Home" asp-action="Dashboard" class="btn btn-outline-secondary">← Back</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.Goal))
    {
        <div class="alert alert-info">🎯 <strong>Goal:</strong> @Model.Goal</div>
    }

    @if (total > 0)
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body py-3">
                <div class="d-flex justify-content-between small mb-1">
                    <span class="fw-semibold">Overall Progress</span>
                    <span class="fw-bold">@completed / @total tasks completed</span>
                </div>
                <div class="progress" style="height: 10px; border-radius: 8px;">
                    <div class="progress-bar @(percent == 100 ? "bg-success" : percent >= 50 ? "bg-primary" : "bg-warning")"
                         style="width: @percent%; border-radius: 8px;"></div>
                </div>
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Tasks (@total)</span>
            @if (User.IsInRole("Coach"))
            {
                <a asp-controller="TaskItems" asp-action="Create"
                   asp-route-trainingPlanId="@Model.TrainingPlanId"
                   class="btn btn-sm btn-primary">+ Add Task</a>
            }
        </div>
        <div class="card-body p-0">
            @if (!Model.Tasks.Any())
            {
                <p class="text-muted p-3 mb-0">
                    No tasks added yet.
                    @if (User.IsInRole("Coach"))
                    {
                        <a asp-controller="TaskItems" asp-action="Create"
                           asp-route-trainingPlanId="@Model.TrainingPlanId">
                            Add the first task →
                        </a>
                    }
                </p>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var task in Model.Tasks)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                            <div class="flex-grow-1">
                                <div class="fw-semibold @(task.Status == ModelTaskStatus.Completed ? "text-decoration-line-through text-muted" : "")">
                                    @task.Title
                                </div>
                                @if (!string.IsNullOrEmpty(task.Description))
                                {
                                    <div class="text-muted small">@task.Description</div>
                                }
                                @if (task.DueDate.HasValue)
                                {
                                    <div class="text-muted small">📅 Due: @task.DueDate.Value.ToString("MMM d, yyyy")</div>
                                }
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge @(task.Status == ModelTaskStatus.Completed ? "bg-success" : task.Status == ModelTaskStatus.InProgress ? "bg-warning text-dark" : "bg-secondary")">
                                    @task.Status
                                </span>
                                @if (User.IsInRole("Athlete"))
                                {
                                    <form asp-controller="TaskItems" asp-action="ToggleStatus"
                                          asp-route-id="@task.TaskItemId" method="post">
                                        <button type="submit" class="btn btn-sm
                                            @(task.Status == ModelTaskStatus.Completed ? "btn-success" :
                                              task.Status == ModelTaskStatus.InProgress ? "btn-warning" :
                                              "btn-outline-secondary")">
                                            @(task.Status == ModelTaskStatus.Completed ? "✅ Done" :
                                              task.Status == ModelTaskStatus.InProgress ? "🔄 In Progress" :
                                              "⬜ Not Started")
                                        </button>
                                    </form>
                                }
                                @if (User.IsInRole("Coach"))
                                {
                                    <a asp-controller="TaskItems" asp-action="Edit"
                                       asp-route-id="@task.TaskItemId"
                                       class="btn btn-sm btn-outline-secondary">Edit</a>
                                    <a asp-controller="TaskItems" asp-action="Delete"
                                       asp-route-id="@task.TaskItemId"
                                       class="btn btn-sm btn-outline-danger">Delete</a>
                                }
                            </div>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</div>