@using Microsoft.AspNetCore.Mvc.Rendering
@model ProTracker.Models.TrainingPlan

@{
    ViewData["Title"] = "Create Training Plan";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="fw-bold mb-1">📋 Create Training Plan</h2>
                    <p class="text-muted mb-4">Fill in the details for your athlete's plan</p>

                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-semibold">Plan Title</label>
                            <input asp-for="Title" class="form-control" placeholder="e.g. 8-Week Strength Program" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Goal" class="form-label fw-semibold">Goal</label>
                            <input asp-for="Goal" class="form-control" placeholder="e.g. Build upper body strength" />
                            <span asp-validation-for="Goal" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StartDate" class="form-label fw-semibold">Start Date</label>
                                <input asp-for="StartDate" type="date" class="form-control" />
                                <span asp-validation-for="StartDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EndDate" class="form-label fw-semibold">End Date</label>
                                <input asp-for="EndDate" type="date" class="form-control" />
                                <span asp-validation-for="EndDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="AthleteId" class="form-label fw-semibold">Assign to Athlete</label>
                            <select asp-for="AthleteId" 
                                    asp-items="(IEnumerable<SelectListItem>)ViewBag.Athletes" 
                                    class="form-select">
                                <option value="">-- Select Athlete --</option>
                            </select>
                            <span asp-validation-for="AthleteId" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4">Create Plan</button>
                            <a asp-controller="Dashboard" asp-action="CoachDashboard" 
                               class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}