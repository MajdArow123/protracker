@model IEnumerable<ProTracker.Models.TrainingPlan>

@{
    ViewData["Title"] = "Training Plans";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Training Plans</h1>
    <a asp-action="Create" class="btn btn-success">+ Create New Plan</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No training plans yet. Click <strong>Create New Plan</strong> to get started!
    </div>
}
else
{
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Goal</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Status</th>
                <th>Progress</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var p in Model)
        {
            var today = DateTime.Today;
            var statusLabel = today < p.StartDate ? "Upcoming" :
                              today > p.EndDate ? "Completed" : "Active";
            var statusClass = statusLabel == "Active" ? "badge bg-success" :
                              statusLabel == "Upcoming" ? "badge bg-warning text-dark" :
                              "badge bg-secondary";

            var totalTasks = p.Tasks.Count;
            var completedTasks = p.Tasks.Count(t => t.Status == ProTracker.Models.TaskStatus.Completed);
            var progressPercent = totalTasks > 0 ? (int)((double)completedTasks / totalTasks * 100) : 0;
            var progressBarClass = progressPercent == 100 ? "bg-success" :
                                   progressPercent >= 50 ? "bg-warning" : "bg-danger";

            <tr>
                <td><strong>@p.Title</strong></td>
                <td>@p.Goal</td>
                <td>@p.StartDate.ToString("MMM dd, yyyy")</td>
                <td>@p.EndDate.ToString("MMM dd, yyyy")</td>
                <td><span class="@statusClass">@statusLabel</span></td>
                <td style="min-width: 150px;">
                    @if (totalTasks == 0)
                    {
                        <span class="text-muted small">No tasks yet</span>
                    }
                    else
                    {
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar @progressBarClass"
                                 role="progressbar"
                                 style="width: @progressPercent%"
                                 aria-valuenow="@progressPercent"
                                 aria-valuemin="0"
                                 aria-valuemax="100">
                                @progressPercent%
                            </div>
                        </div>
                        <small class="text-muted">@completedTasks / @totalTasks tasks done</small>
                    }
                </td>
                <td>
    <a asp-controller="TaskItems"
       asp-action="Index"
       asp-route-trainingPlanId="@p.TrainingPlanId"
       class="btn btn-sm btn-primary">
        View Tasks
    </a>
    <a asp-action="Edit"
       asp-route-id="@p.TrainingPlanId"
       class="btn btn-sm btn-outline-secondary">
        Edit
    </a>
    <a asp-action="Delete"
       asp-route-id="@p.TrainingPlanId"
       class="btn btn-sm btn-outline-danger">
        Delete
    </a>
</td>
            </tr>
        }
        </tbody>
    </table>
}