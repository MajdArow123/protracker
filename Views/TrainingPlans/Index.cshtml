@model IEnumerable<ProTracker.Models.TrainingPlan>

@{
    ViewData["Title"] = "Training Plans";
}

<h1>Training Plans</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Create New Training Plan</a>
</p>

@if (!Model.Any())
{
    <p>No training plans yet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Goal</th>
                <th>Start</th>
                <th>End</th>
                <th>Athlete</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Title</td>
                <td>@p.Goal</td>
                <td>@p.StartDate.ToString("yyyy-MM-dd")</td>
                <td>@p.EndDate.ToString("yyyy-MM-dd")</td>
                <td>@p.AthleteId</td>
                <td>
                    <a asp-controller="TaskItems"
                       asp-action="Index"
                       asp-route-trainingPlanId="@p.TrainingPlanId"
                       class="btn btn-sm btn-primary">
                        View Tasks
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}